import random

def gen_pass(pass_length):
    elements = "+-/*!&$#?=@<>1234567890zxcvbnmasdfghjklqwertyuiopQWERTYUIOPASDFGHJKLZXCVBNM"
    password = ""
    for i in range(int(pass_length)):
        password += random.choice(elements)
    return password
