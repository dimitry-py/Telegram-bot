@bot.message_handler(commands=['password'])
def send_pass(message):
  try:
    # Attempt to get the length from the message, default to 10 if not provided or invalid
    pass_length = int(message.text.split()[1])
  except (IndexError, ValueError):
    pass_length = 10 # Default length
  bot.reply_to(message, gen_pass(pass_length))

